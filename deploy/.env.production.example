# Napolitan API - Production Environment
# Copy this file to .env and fill in the values

# Application
NODE_ENV=production
PORT=3000
APP_PORT=3000

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=napolitan
DATABASE_URL=postgresql://postgres:your_secure_postgres_password_here@localhost:5432/napolitan

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# JWT (Generate secure random strings - minimum 32 characters)
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_characters_here
JWT_REFRESH_EXPIRES_IN=7d

# CORS (Allowed origins - comma separated)
# Include your Cloudflare Pages domain and any custom admin domains
ALLOWED_ORIGINS=https://napolitan-admin.pages.dev,https://admin.napolitan.com
