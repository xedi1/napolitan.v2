// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  orders    Order[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  KITCHEN
}

// Category model for menu items
model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  displayOrder Int       @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  menuItems   MenuItem[]

  @@map("categories")
}

// MenuItem model
model MenuItem {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])

  orderItems  OrderItem[]
  recipe      Recipe?

  @@map("menu_items")
}

// Table model
model Table {
  id          String      @id @default(uuid())
  tableNumber Int         @unique
  capacity    Int
  status      TableStatus @default(EMPTY)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders      Order[]

  @@map("tables")
}

enum TableStatus {
  EMPTY
  RESERVED
  OCCUPIED
}

// Order model
model Order {
  id          String      @id @default(uuid())
  tableId     String
  table       Table       @relation(fields: [tableId], references: [id])
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Decimal?    @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
  receipt     Receipt?

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

// OrderItem model (for future phases)
model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())

  @@map("order_items")
}

// Payment method enum
enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

// Receipt model
model Receipt {
  id              String        @id @default(uuid())
  receiptNumber   String        @unique // Format: NP-YYYY-NNNNN
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  totalAmount     Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())

  // Online receipt link (optional)
  receiptUrl      String?
  qrCodeData      String?

  @@map("receipts")
}

// Measurement unit enum
enum MeasurementUnit {
  KG
  GRAM
  LITER
  ML
  PIECE
  CUP
  SPOON
}

// Inventory Item model
model InventoryItem {
  id            String           @id @default(uuid())
  name          String
  unit          MeasurementUnit
  currentStock  Decimal          @db.Decimal(10, 2)
  alertLevel    Decimal          @db.Decimal(10, 2)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  recipeItems   RecipeItem[]

  @@map("inventory_items")
}

// Recipe model (links menu items to inventory items)
model Recipe {
  id          String       @id @default(uuid())
  menuItemId  String       @unique
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items       RecipeItem[]

  @@map("recipes")
}

// Recipe Item model (ingredient with quantity)
model RecipeItem {
  id              String        @id @default(uuid())
  recipeId        String
  recipe          Recipe        @relation(fields: [recipeId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @db.Decimal(10, 2) // Amount consumed per order
  createdAt       DateTime      @default(now())

  @@map("recipe_items")
}

// Shift status enum
enum ShiftStatus {
  OFF
  ON_DUTY
  BREAK
}

// Employee model
model Employee {
  id            String      @id @default(uuid())
  firstName     String
  lastName      String
  email         String      @unique
  phone         String?
  role          UserRole
  position      String?     // e.g., "Head Chef", "Waiter", "Cashier"
  hourlyRate    Decimal?    @db.Decimal(10, 2)
  isActive      Boolean     @default(true)
  hireDate      DateTime    @default(now())
  shiftStatus   ShiftStatus @default(OFF)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("employees")
}

// Analytics cache for dashboard performance
model DailyAnalytics {
  id              String   @id @default(uuid())
  date            DateTime @db.Date
  totalOrders     Int      @default(0)
  totalRevenue    Decimal  @db.Decimal(12, 2) @default(0)
  totalItemsSold  Int      @default(0)
  avgOrderValue   Decimal  @db.Decimal(10, 2) @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date])
  @@map("daily_analytics")
}

// Menu item sales tracking
model MenuItemSales {
  id            String    @id @default(uuid())
  menuItemId    String
  date          DateTime  @db.Date
  quantitySold  Int       @default(0)
  revenue       Decimal   @db.Decimal(12, 2) @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([menuItemId, date])
  @@map("menu_item_sales")
}

// Notification type enum
enum NotificationType {
  ORDER_NEW
  ORDER_STATUS_CHANGED
  PAYMENT_SUCCESS
  INVENTORY_LOW_STOCK
  RECEIPT_ISSUED
  SYSTEM_ALERT
}

// Notification recipient type
enum NotificationRecipient {
  ALL
  KITCHEN
  CASHIER
  MANAGER
  ADMIN
}

// Notification model
model Notification {
  id          String               @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  recipient   NotificationRecipient @default(ALL)
  metadata    Json?                // Additional event data
  isRead      Boolean             @default(false)
  readAt      DateTime?
  userId      String?             // Optional: specific user
  createdAt   DateTime            @default(now())

  @@map("notifications")
}

// Audit log action type
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  ORDER_CREATE
  ORDER_UPDATE
}

// Audit log model
model AuditLog {
  id         String       @id @default(uuid())
  event      String       // Event name
  action     AuditAction
  entityType String?      // e.g., "Order", "Receipt", "User"
  entityId   String?      // ID of the affected entity
  userId     String?      // User who performed the action
  userEmail  String?     // User email at time of action
  ipAddress  String?
  userAgent  String?
  metadata    Json?       // Additional event data
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("audit_logs")
}

// API Key permission level
enum ApiKeyPermission {
  READ
  WRITE
  ADMIN
}

// API Key model
model ApiKey {
  id          String          @id @default(uuid())
  name        String          // Friendly name for the key
  key         String          @unique // The actual API key (hashed stored)
  keyPrefix   String          // First 8 chars for identification
  permissions ApiKeyPermission @default(READ)
  isActive    Boolean         @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  webhooks    Webhook[]

  @@index([key])
  @@map("api_keys")
}

// Webhook model
model Webhook {
  id          String   @id @default(uuid())
  name        String   // Friendly name
  url         String   // Destination URL
  secret      String   // Secret for HMAC signing
  events      String[] // Events to subscribe to
  isActive    Boolean  @default(true)
  apiKeyId    String
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id])
  headers     Json?    // Custom headers to send
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        WebhookLog[]

  @@index([apiKeyId])
  @@map("webhooks")
}

// Webhook delivery status
enum WebhookStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

// Webhook log model
model WebhookLog {
  id           String        @id @default(uuid())
  webhookId    String
  webhook      Webhook       @relation(fields: [webhookId], references: [id])
  event        String        // Event that triggered this delivery
  payload      Json          // What was sent
  responseCode Int?          // HTTP response code
  responseBody String?       // Response body (truncated)
  status       WebhookStatus @default(PENDING)
  attempt      Int           @default(1)
  error        String?       // Error message if failed
  duration     Int?          // Duration in ms
  createdAt    DateTime      @default(now())

  @@index([webhookId])
  @@index([event])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_logs")
}

// Rate limit tracking
model RateLimit {
  id        String   @id @default(uuid())
  apiKeyId  String
  windowStart DateTime
  requestCount Int   @default(0)

  @@unique([apiKeyId, windowStart])
  @@map("rate_limits")
}
